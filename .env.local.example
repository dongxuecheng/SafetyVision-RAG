# SafetyVision-RAG 环境变量配置 - 本地完整部署模式
# 复制此文件为 .env 并填写实际配置

# ========== 部署模式 ==========
DEPLOYMENT_MODE=local

# ========== Qdrant配置 ==========
QDRANT_HOST=qdrant-server
QDRANT_PORT=6333

# ========== 本地vLLM服务配置 ==========
# LLM/VLM服务 (Qwen3-VL-4B同时提供图像和文本能力)
VLLM_LLM_URL=http://vllm-qwen-vl:8000/v1
VLLM_LLM_MODEL=/model/qwen3-vl-4b

# 嵌入模型服务
VLLM_EMBED_URL=http://vllm-bge-m3:8000/v1
VLLM_EMBED_MODEL=/model/bge-m3

# Reranker服务
VLLM_RERANK_URL=http://vllm-bge-reranker:8000
VLLM_RERANK_MODEL=/model/bge-reranker-v2-m3

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_ROTATION=100 MB
LOG_RETENTION=30 days

# ========== RAG检索配置 (可选，使用默认值) ==========
# RETRIEVAL_SCORE_THRESHOLD=0.2
# RERANK_SCORE_THRESHOLD=0.3
# REGULATIONS_RETRIEVAL_K=5
# HAZARD_DB_RETRIEVAL_K=5
