# SafetyVision-RAG 环境变量配置 - 阿里云API模式
# 复制此文件为 .env 并填写实际配置

# ========== 部署模式 ==========
DEPLOYMENT_MODE=aliyun

# ========== 模型存储路径 ==========
MODEL_BASE_PATH=/home/xcd/vllm/model

# ========== 阿里云DashScope API ==========
DASHSCOPE_API_KEY=sk-your-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== 模型配置 ==========
# 统一的多模态大模型配置（兼容文本与图片）
LLM_MODEL_NAME=qwen-vl-max-latest

# ========== Qdrant配置 ==========
QDRANT_HOST=qdrant-server
QDRANT_PORT=6333

# ========== 本地vLLM服务（Embedding & Reranker） ==========
VLLM_EMBED_URL=http://vllm-bge-m3:8000/v1
VLLM_EMBED_MODEL=/model/bge-m3
VLLM_RERANK_URL=http://vllm-bge-reranker:8000
VLLM_RERANK_MODEL=/model/bge-reranker-v2-m3

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_ROTATION=100 MB
LOG_RETENTION=30 days


