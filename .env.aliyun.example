# Aliyun DashScope API Configuration
# Get your API key from: https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-your-api-key-here

# Model Configuration
# VLM for image analysis (multimodal)
VLM_MODEL_NAME=qwen3-vl-plus

# LLM for RAG QA (text-only)
LLM_MODEL_NAME=qwen3-max-preview

# DashScope Base URL
# Beijing region (default): https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore region: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Self-hosted Embedding Model (BGE-M3 via vLLM)
VLLM_EMBED_URL=http://vllm-bge-m3:8000/v1
VLLM_EMBED_MODEL=/model/bge-m3

# Self-hosted Reranker Model (BGE-Reranker-v2-M3 via vLLM)
VLLM_RERANK_URL=http://vllm-bge-reranker:8000
VLLM_RERANK_MODEL=/model/bge-reranker-v2-m3

# Qdrant Vector Database
QDRANT_HOST=qdrant-server
QDRANT_PORT=6333
